#!/usr/bin/env python3

import json
import os
import subprocess
import sys
from datetime import datetime, timezone

from prompt_toolkit import Application
from prompt_toolkit.buffer import Buffer
from prompt_toolkit.document import Document
from prompt_toolkit.key_binding import KeyBindings
from prompt_toolkit.layout.containers import HSplit, VSplit, Window
from prompt_toolkit.layout.controls import BufferControl, FormattedTextControl
from prompt_toolkit.layout.dimension import Dimension as D
from prompt_toolkit.layout.layout import Layout
from prompt_toolkit.styles import Style
from prompt_toolkit.widgets import Frame

SCRIPT_DIR = os.path.dirname(os.path.realpath(__file__))
POSTS_FILE = os.path.join(SCRIPT_DIR, "posts.json")


def load_posts():
    if not os.path.exists(POSTS_FILE):
        return []
    with open(POSTS_FILE, "r") as f:
        content = f.read().strip()
        if not content:
            return []
        return json.loads(content)


def save_posts(posts):
    with open(POSTS_FILE, "w") as f:
        json.dump(posts, f, indent=2, ensure_ascii=False)
        f.write("\n")


def make_post(text, tags, title=None):
    now = datetime.now(timezone.utc).astimezone()
    post = {
        "id": now.strftime("%Y%m%d%H%M%S"),
        "text": text,
        "tags": tags,
        "timestamp": now.isoformat(),
    }
    if title:
        post["title"] = title
    return post


def git_push(text, action="post"):
    preview = text[:50] + ("..." if len(text) > 50 else "")
    msg = f"{action}: {preview}"
    try:
        subprocess.run(["git", "add", "posts.json"], cwd=SCRIPT_DIR, check=True)
        subprocess.run(["git", "commit", "-m", msg], cwd=SCRIPT_DIR, check=True)
        subprocess.run(["git", "pull", "--rebase"], cwd=SCRIPT_DIR, check=True)
        subprocess.run(["git", "push"], cwd=SCRIPT_DIR, check=True)
    except subprocess.CalledProcessError as e:
        print(f"git error: {e}", file=sys.stderr)
        print("post saved locally but not pushed.", file=sys.stderr)
        return False
    return True


def recent_posts_widget():
    posts = load_posts()[:3]
    if not posts:
        return []

    fragments = []
    for i, post in enumerate(posts):
        ts = post.get("timestamp", "")
        try:
            dt = datetime.fromisoformat(ts)
            date_str = dt.strftime("%b %d, %H:%M")
        except (ValueError, TypeError):
            date_str = ""

        text = post.get("text", "")
        lines = text.split("\n")
        preview = lines[0][:80]
        if len(lines) > 1 or len(lines[0]) > 80:
            preview += "..."

        fragments.append(("class:post-text", f"  {preview}\n"))
        tags = post.get("tags", [])
        meta = ""
        if tags:
            meta += " ".join(f"#{t}" for t in tags) + "  "
        meta += date_str
        fragments.append(("class:post-meta", f"  {meta}\n"))
        if i < len(posts) - 1:
            fragments.append(("class:post-meta", "\n"))

    return [
        Window(
            height=1,
            content=FormattedTextControl([("class:title", "  recent")]),
        ),
        Window(height=1),
        Window(
            content=FormattedTextControl(fragments),
            dont_extend_height=True,
            wrap_lines=True,
        ),
        Window(height=1),
    ]


def picker(posts, action="edit"):
    if not posts:
        return None

    selected = [0]

    def get_fragments():
        fragments = []
        for i, post in enumerate(posts):
            ts = post.get("timestamp", "")
            try:
                dt = datetime.fromisoformat(ts)
                date_str = dt.strftime("%b %d, %H:%M")
            except (ValueError, TypeError):
                date_str = ""

            prefix_style = "class:picker-selected" if i == selected[0] else "class:picker-item"
            pointer = "  > " if i == selected[0] else "    "
            fragments.append((prefix_style, pointer))

            title = post.get("title", "")
            text = post.get("text", "")
            preview = title if title else text.split("\n")[0][:60]
            if len(preview) > 60:
                preview = preview[:57] + "..."
            fragments.append((prefix_style, preview))

            fragments.append(("class:picker-meta", f"  {date_str}"))
            tags = post.get("tags", [])
            if tags:
                fragments.append(("class:picker-meta", "  " + " ".join(f"#{t}" for t in tags)))
            fragments.append(("", "\n"))
        return fragments

    list_control = FormattedTextControl(get_fragments)
    list_window = Window(content=list_control, dont_extend_height=True, wrap_lines=True)

    header = Window(
        height=1,
        content=FormattedTextControl([("class:title", f"  select post to {action}")]),
    )

    hint = Window(
        height=1,
        content=FormattedTextControl([
            ("class:hint", "  "),
            ("class:key", "Up/Down "), ("class:hint", "navigate"),
            ("class:sep", "  ·  "),
            ("class:key", "Enter "), ("class:hint", "select"),
            ("class:sep", "  ·  "),
            ("class:key", "Ctrl+C "), ("class:hint", "back"),
        ]),
    )

    pad = 4
    root = HSplit([
        Window(height=D(weight=1)),
        VSplit([
            Window(width=pad),
            HSplit([header, Window(height=1), list_window, Window(height=1), hint]),
            Window(width=pad),
        ]),
        Window(height=D(weight=1)),
    ])

    kb = KeyBindings()

    @kb.add("up")
    def move_up(event):
        if selected[0] > 0:
            selected[0] -= 1

    @kb.add("down")
    def move_down(event):
        if selected[0] < len(posts) - 1:
            selected[0] += 1

    @kb.add("enter", eager=True)
    def select(event):
        event.app.exit(result=selected[0])

    @kb.add("c-c")
    def cancel(event):
        event.app.exit(result=None)

    style = Style.from_dict({
        "title": "#7ab0d2 bold",
        "picker-selected": "#ffffff bold",
        "picker-item": "#888888",
        "picker-meta": "#555555",
        "key": "#999999",
        "hint": "#555555",
        "sep": "#444444",
    })

    app = Application(
        layout=Layout(root),
        key_bindings=kb,
        full_screen=True,
        style=style,
    )
    return app.run()


def editor(initial_title="", initial_body="", initial_tags=""):
    title_buffer = Buffer(document=Document(initial_title, len(initial_title)))
    body_buffer = Buffer(multiline=True, document=Document(initial_body, len(initial_body)))
    tags_buffer = Buffer(document=Document(initial_tags, len(initial_tags)))

    title_window = Window(content=BufferControl(buffer=title_buffer), height=1)
    body_window = Window(
        content=BufferControl(buffer=body_buffer),
        wrap_lines=True,
    )
    tags_window = Window(content=BufferControl(buffer=tags_buffer), height=1)

    def separator():
        return Window(height=1, char="─", style="class:separator")

    inner = HSplit([
        Window(height=1, content=FormattedTextControl([("class:label", "  title (optional)")])),
        title_window,
        separator(),
        Window(height=1, content=FormattedTextControl([("class:label", "  body")])),
        body_window,
        separator(),
        Window(height=1, content=FormattedTextControl([("class:label", "  tags")])),
        tags_window,
        Window(height=1),
    ])

    padded = VSplit([
        Window(width=2),
        inner,
        Window(width=2),
    ])

    title = Window(
        height=1,
        content=FormattedTextControl([("class:title", "  new post")]),
    )

    framed = Frame(padded)

    hint = Window(
        height=1,
        content=FormattedTextControl([
            ("class:hint", "  "),
            ("class:key", "Ctrl+S "), ("class:hint", "post"),
            ("class:sep", "  ·  "),
            ("class:key", "Tab "), ("class:hint", "next field"),
            ("class:sep", "  ·  "),
            ("class:key", "Ctrl+E "), ("class:hint", "edit prev"),
            ("class:sep", "  ·  "),
            ("class:key", "Ctrl+D "), ("class:hint", "delete prev"),
            ("class:sep", "  ·  "),
            ("class:key", "Ctrl+C "), ("class:hint", "cancel"),
        ]),
    )

    pad = 4
    root = HSplit([
        Window(height=D(weight=1)),
        VSplit([
            Window(width=pad),
            HSplit(recent_posts_widget() + [title, framed, hint]),
            Window(width=pad),
        ]),
        Window(height=D(weight=1)),
    ])

    kb = KeyBindings()

    @kb.add("enter", eager=True)
    def newline_or_noop(event):
        if event.app.layout.has_focus(body_window):
            event.current_buffer.insert_text("\n")

    @kb.add("c-s")
    def submit(event):
        event.app.exit(result="submit")

    @kb.add("c-c")
    def cancel(event):
        event.app.exit(result="cancel")

    @kb.add("c-e")
    def edit_mode(event):
        event.app.exit(result="edit")

    @kb.add("c-d")
    def delete_mode(event):
        event.app.exit(result="delete")

    @kb.add("tab")
    def toggle_focus(event):
        if event.app.layout.has_focus(title_window):
            event.app.layout.focus(body_window)
        elif event.app.layout.has_focus(body_window):
            event.app.layout.focus(tags_window)
        else:
            event.app.layout.focus(title_window)

    style = Style.from_dict({
        "frame.border": "#cccccc",
        "title": "#7ab0d2 bold",
        "label": "#666666",
        "key": "#999999",
        "hint": "#555555",
        "sep": "#444444",
        "post-text": "#888888",
        "post-meta": "#555555",
        "separator": "#333333",
    })

    app = Application(
        layout=Layout(root, focused_element=title_window),
        key_bindings=kb,
        full_screen=True,
        style=style,
    )
    result = app.run()

    if result == "cancel":
        return None

    title = title_buffer.text.strip() or None
    text = body_buffer.text.strip()
    tags_str = tags_buffer.text.strip()
    tags = [t.strip() for t in tags_str.split(",") if t.strip()] if tags_str else []
    return (title, text, tags)


def print_preview(title, text, tags):
    print()
    if title:
        print(f"  {title}")
    print(f"  {text[:80]}{'...' if len(text) > 80 else ''}")
    if tags:
        print(f"  {' '.join(f'#{t}' for t in tags)}")
    print()


def handle_new_post():
    init_title, init_body, init_tags = "", "", ""
    while True:
        result = editor(init_title, init_body, init_tags)
        if result is None:
            print("cancelled.")
            return
        if result in ("edit", "delete"):
            return result

        title, text, tags = result
        if not text:
            print("empty post, nothing to do.")
            return

        print_preview(title, text, tags)
        confirm = input("post? (y/n/e) ").strip().lower()
        if confirm == "y":
            post = make_post(text, tags, title=title)
            posts = load_posts()
            posts.insert(0, post)
            save_posts(posts)
            print("posted")
            git_push(text)
            return
        elif confirm == "e":
            init_title = title or ""
            init_body = text
            init_tags = ", ".join(tags) if tags else ""
            continue
        else:
            print("cancelled.")
            return


def handle_edit_post():
    posts = load_posts()
    if not posts:
        print("no posts to edit.")
        return

    idx = picker(posts, action="edit")
    if idx is None:
        return "new"

    post = posts[idx]
    init_title = post.get("title", "")
    init_body = post.get("text", "")
    init_tags = ", ".join(post.get("tags", []))

    while True:
        result = editor(init_title, init_body, init_tags)
        if result is None:
            print("cancelled edit.")
            return
        if result in ("edit", "delete"):
            return result

        title, text, tags = result
        if not text:
            print("empty post, nothing to do.")
            return

        print_preview(title, text, tags)
        confirm = input("save edit? (y/n/e) ").strip().lower()
        if confirm == "y":
            posts[idx]["text"] = text
            posts[idx]["tags"] = tags
            if title:
                posts[idx]["title"] = title
            elif "title" in posts[idx]:
                del posts[idx]["title"]
            save_posts(posts)
            print("edited")
            git_push(text, action="post: edit")
            return
        elif confirm == "e":
            init_title = title or ""
            init_body = text
            init_tags = ", ".join(tags) if tags else ""
            continue
        else:
            print("cancelled edit.")
            return


def handle_delete_post():
    posts = load_posts()
    if not posts:
        print("no posts to delete.")
        return

    idx = picker(posts, action="delete")
    if idx is None:
        return "new"

    post = posts[idx]
    title = post.get("title")
    text = post.get("text", "")
    tags = post.get("tags", [])

    print_preview(title, text, tags)
    confirm = input("delete this post? (y/n) ").strip().lower()
    if confirm == "y":
        posts.pop(idx)
        save_posts(posts)
        print("deleted")
        git_push(text, action="post: delete")
    else:
        print("cancelled delete.")


def main():
    mode = "new"
    while mode:
        if mode == "new":
            mode = handle_new_post()
        elif mode == "edit":
            mode = handle_edit_post()
        elif mode == "delete":
            mode = handle_delete_post()
            mode = None
        else:
            mode = None


if __name__ == "__main__":
    main()
